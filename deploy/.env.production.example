# ============================================================================
# SaviSanju Collections API — PRODUCTION environment template
# ============================================================================
# Copy to /etc/savisanju/api.env, fill in real secrets, then `chmod 600`.
# NEVER commit the filled-in file. This template contains placeholders only.
# ============================================================================

NODE_ENV=production
PORT=5000

# Public URLs
# API_URL is the public HTTPS hostname Nginx serves; FRONTEND_URL is your Vercel app.
API_URL=https://api.savisanju.com
FRONTEND_URL=https://savisanju.vercel.app

# ── Database (PostgreSQL) ──
# Use the LEAST-PRIVILEGE application role created in migration 009, NOT `postgres`.
# Connecting as `savisanju_app` is what ACTIVATES Row Level Security (see 009/010).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=savisanju
DB_USER=savisanju_app
# Set the role's password out-of-band:
#   sudo -u postgres psql -c "ALTER ROLE savisanju_app WITH LOGIN PASSWORD '<strong>';"
DB_PASSWORD=__CHANGE_ME_STRONG_DB_PASSWORD__
# Modest pool for a 2 GB box; keep below Postgres max_connections.
DB_POOL_MAX=10

# ── JWT / Cookie secrets ──
# Generate each with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=__CHANGE_ME_64_BYTE_HEX__
JWT_EXPIRES_IN=24h
COOKIE_SECRET=__CHANGE_ME_64_BYTE_HEX__

# ── Reverse proxy ──
# Exactly one Nginx hop in front of the app (must be a number, never `true`).
TRUST_PROXY_HOPS=1

# ── Admin bootstrap ──
# Admin is granted via the DB `role` column (migration 008), NOT by this email.
# Create the admin once with:
#   ADMIN_EMAIL=you@example.com ADMIN_PASSWORD='<strong>' npx tsx scripts/create-admin.ts
ADMIN_EMAIL=you@example.com
ADMIN_NAME=Administrator

# ── Email service (Resend) ──
RESEND_API_KEY=re___CHANGE_ME__
RESEND_FROM_EMAIL=orders@savisanju.com
RESEND_ADMIN_EMAIL=admin@savisanju.com

# ── File upload ──
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# ── Redis (OPTIONAL) ──
# NOTE: Redis is NOT currently wired into the app (initRedis() is never called);
# rate limiting is in-memory, which is fine for this single-instance deployment.
# These are placeholders for if/when Redis is integrated.
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=__CHANGE_ME__
