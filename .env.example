# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
# TODO: Change to your Vercel URL in production (e.g., https://savisanju.vercel.app)
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=savisanju
DB_USER=postgres
# TODO: Change to a strong password in production
DB_PASSWORD=password

# JWT Authentication
# TODO: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED in production - backend will exit if not set
JWT_SECRET=your-random-256-bit-secret-here
JWT_EXPIRES_IN=24h

# Cookie Security
# TODO: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED in production - backend will exit if not set
COOKIE_SECRET=your-cookie-secret-here

# Admin Configuration
# Admin access is determined by the `role` column in the database (see migration 008),
# NOT by matching this email. Create/rotate the admin account securely with:
#   ADMIN_EMAIL=you@example.com ADMIN_PASSWORD='<strong-password>' npx tsx scripts/create-admin.ts
# ADMIN_PASSWORD is only read at bootstrap time and is never committed.
ADMIN_EMAIL=
ADMIN_NAME=Administrator

# Reverse proxy / rate limiting
# Number of trusted proxy hops in front of the API (e.g. 1 for a single Nginx).
# MUST be a number (never `true`) so client IPs cannot be spoofed to bypass rate limits.
# Defaults to 1 in production, 0 in development.
TRUST_PROXY_HOPS=1

# Email Service (Resend)
# TODO: Get API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here
# TODO: Change to your verified domain
RESEND_FROM_EMAIL=orders@savisanju.com
RESEND_ADMIN_EMAIL=admin@savisanju.com

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp
